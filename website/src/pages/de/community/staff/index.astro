---
import ContentPage from "../../../../components/ContentPage.astro";
import ContentPanel from "../../../../components/ContentPanel.astro";
import Gallery from "../../../../components/Gallery.astro";
import { resolveImages } from "../../../../data/images";

const landscapeStaff = resolveImages(["staff/domino.jpg", "staff/alice.png"]);
---

<ContentPage
  title="Staff | Tiny Temptation Tubs"
  lang="de"
  path="/de/community/staff/"
  heading="Staff"
>
  <ContentPanel>
    <div class="hand-text flex flex-col gap-6">
      <p>
        <em
          ><strong
            >Hinter jedem warmen Empfang stehen jene,<br /> die sich um das Haus kümmern.</strong
          ></em
        >
      </p>
      <p>
        <em
          ><strong
            >Unsere Gastgeber, Helfer und Wächter<br /> sorgen dafür, dass jeder Moment
            angenehm bleibt.</strong
          ></em
        >
      </p>
      <p>
        <em
          ><strong
            >Sie halten das Gleichgewicht,<br /> damit sich jeder sicher und willkommen
            fühlt.</strong
          ></em
        >
      </p>
    </div>
  </ContentPanel>
  <Gallery
    cols={5}
    altPrefix="Staff portrait"
    images={resolveImages([
      "staff/reiji.jpg",
      "staff/soldea.jpg",
      "staff/domi.jpg",
      "staff/elphine.jpg",
      "staff/ralvus.png",
    ])}
  />
  <Gallery
    cols={2}
    altPrefix="Staff portrait"
    class="w-full"
    images={landscapeStaff}
  />
</ContentPage>
