---
import ContentPage from "../../../components/ContentPage.astro";
import Gallery from "../../../components/Gallery.astro";
import { resolveImages } from "../../../data/images";
---

<ContentPage
  title="Gästebuch | Tiny Temptation Tubs"
  lang="de"
  path="/de/gaestebuch/"
  heading="Gästebuch"
  gallery
>
  <Fragment slot="intro">
    <p class="hand-text">
      Nachrichten unserer Gäste aus dem Gästebuch unserer XIV-Location — hier
      als Screenshots festgehalten.
    </p>
    <p class="hand-text">
      <em
        ><strong
          >Man sagt, Worte können bleiben… Hinterlasse ein Stück von dir, ein
          paar Gedanken oder Erinnerungen — damit deine Reise bei uns niemals
          ganz vergeht.</strong
        ></em
      >
    </p>
  </Fragment>
  <Gallery
    wide
    altPrefix="Gästebuch-Nachricht"
    images={resolveImages([
      "guestbook/b04b2349.jpg",
      "guestbook/fb0b75e8.jpg",
      "guestbook/228b4f2a.jpg",
      "guestbook/ca8d23e8.jpg",
      "guestbook/ab7b15ef.jpg",
      "guestbook/4422e621.jpg",
      "guestbook/ca8cef1a.jpg",
      "guestbook/895a9878.jpg",
    ])}
  />
</ContentPage>
