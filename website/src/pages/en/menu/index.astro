---
import ContentPage from "../../../components/ContentPage.astro";
import ContentImage from "../../../components/ContentImage.astro";
import {
  CONTENT_COLUMN_PX,
  CONTENT_COLUMN_SIZES,
  contentColumnWidths,
} from "../../../data/layout";
import { resolveGallery } from "../../../data/images";
---

<ContentPage
  title="Menu | Tiny Temptation Tubs"
  lang="en"
  path="/en/menu/"
  heading="Menu"
>
  <ContentImage
    src={resolveGallery("gallery24/drinks-menu.png")}
    width={CONTENT_COLUMN_PX}
    sizes={CONTENT_COLUMN_SIZES}
    widths={contentColumnWidths()}
    class="w-full"
    alt="Drinks menu at Tiny Temptation Tubs, served by Ralvus the bartender"
    lightbox
  />
</ContentPage>
