---
import ContentPage from "../../../../components/ContentPage.astro";
import ContentPanel from "../../../../components/ContentPanel.astro";
import Gallery from "../../../../components/Gallery.astro";
import DiscordButton from "../../../../components/DiscordButton.astro";
import { resolveImages } from "../../../../data/images";
import { DISCORD_TTT } from "../../../../data/site";
---

<ContentPage
  title="Join us | Tiny Temptation Tubs"
  lang="en"
  path="/en/community/join/"
  heading="Join Us"
>
  <ContentPanel>
    <div class="hand-text flex flex-col gap-6">
      <p>
        <em
          ><strong
            >Perhaps you are more than just a guest…<br /> If you carry music in your
            heart,<br /> wish to bring joy to others,<br /> or want to become part
            of something greater</strong
          ></em
        >
      </p>
      <p>
        <em
          ><strong>Then we invite you<br /> to become part of our story.</strong
          ></em
        >
      </p>
    </div>
  </ContentPanel>
  <Gallery
    cols={2}
    altPrefix="Community photo"
    class="mx-auto max-w-96"
    images={resolveImages(["community/88d650d3.jpg", "community/7a80e7c4.jpg"])}
  />
  <DiscordButton href={DISCORD_TTT} />
</ContentPage>
