---
import ContentPage from "../../../../components/ContentPage.astro";
import ContentPanel from "../../../../components/ContentPanel.astro";
import Gallery from "../../../../components/Gallery.astro";
import { resolveImages } from "../../../../data/images";

const landscapeStaff = resolveImages(["staff/domino.jpg", "staff/alice.png"]);
---

<ContentPage
  title="Staff | Tiny Temptation Tubs"
  lang="en"
  path="/en/community/staff/"
  heading="Staff"
>
  <ContentPanel>
    <div class="hand-text flex flex-col gap-6">
      <p>
        <em
          ><strong
            >Behind every warm welcome stand those<br /> who care for the house.</strong
          ></em
        >
      </p>
      <p>
        <em
          ><strong
            >Our hosts, helpers, and guardians<br /> ensure every moment remains pleasant.</strong
          ></em
        >
      </p>
      <p>
        <em
          ><strong
            >They keep the balance<br /> so everyone feels safe and welcome.</strong
          ></em
        >
      </p>
    </div>
  </ContentPanel>
  <Gallery
    cols={5}
    altPrefix="Staff portrait"
    images={resolveImages([
      "staff/reiji.jpg",
      "staff/soldea.jpg",
      "staff/domi.jpg",
      "staff/elphine.jpg",
      "staff/ralvus.png",
    ])}
  />
  <Gallery
    cols={2}
    altPrefix="Staff portrait"
    class="w-full"
    images={landscapeStaff}
  />
</ContentPage>
