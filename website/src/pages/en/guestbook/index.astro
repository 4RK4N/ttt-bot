---
import ContentPage from "../../../components/ContentPage.astro";
import Gallery from "../../../components/Gallery.astro";
import { resolveImages } from "../../../data/images";
---

<ContentPage
  title="Guestbook | Tiny Temptation Tubs"
  lang="en"
  path="/en/guestbook/"
  heading="Guestbook"
  gallery
>
  <Fragment slot="intro">
    <p class="hand-text">
      Messages left by our guests in our XIV venue guestbook — shared here as
      screenshots.
    </p>
    <p class="hand-text">
      <em
        ><strong
          >They say words can remain… Leave a piece of yourself, a few thoughts
          or memories so your journey here never truly fades.</strong
        ></em
      >
    </p>
  </Fragment>
  <Gallery
    wide
    aspect="landscape"
    altPrefix="Guestbook message"
    images={resolveImages([
      "guestbook/b04b2349.jpg",
      "guestbook/fb0b75e8.jpg",
      "guestbook/228b4f2a.jpg",
      "guestbook/ca8d23e8.jpg",
      "guestbook/ab7b15ef.jpg",
      "guestbook/4422e621.jpg",
      "guestbook/ca8cef1a.jpg",
      "guestbook/895a9878.jpg",
    ])}
  />
</ContentPage>
