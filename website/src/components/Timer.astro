---
import type { Lang } from "../data/nav";
import { splitRemainingMs } from "../data/countdown";

interface Props {
  lang: Lang;
  /** Unix timestamp (seconds) the countdown targets. */
  timestamp: number;
}

const { lang, timestamp } = Astro.props;

const labels =
  lang === "de"
    ? ["Tage", "Stunden", "Minuten", "Sekunden"]
    : ["Days", "Hours", "Minutes", "Seconds"];

const openMessage = lang === "de" ? "Wir haben geöffnet!" : "We're open!";

const targetMs = timestamp * 1000;
const initialDigits = splitRemainingMs(targetMs - Date.now());
const isOpen = targetMs <= Date.now();
---

<div
  id="event-timer"
  data-timestamp={timestamp}
  data-open-message={openMessage}
  aria-live="polite"
  class="flex w-full max-w-full flex-col items-center sm:max-w-[36rem]"
>
  {
    isOpen ? (
      <p class="font-averia text-[1.5em] font-bold text-timer-digit">
        {openMessage}
      </p>
    ) : (
      <div class="flex w-full min-w-0 items-stretch justify-center font-averia font-bold">
        {labels.map((label, i) => (
          <>
            {i > 0 && <div class="timer-separator" aria-hidden="true" />}
            <div class="timer-unit flex flex-col items-center py-2 sm:py-4">
              <span class="timer-digit-panel">
                <span
                  data-digit
                  class="timer-digit text-[1.45em] leading-none sm:text-[2.5em]"
                >
                  {initialDigits[i]}
                </span>
              </span>
              <span class="timer-label mt-1.5 text-[0.45rem] uppercase tracking-[0.06rem] text-white sm:mt-3 sm:text-[0.625rem] sm:tracking-[0.225rem]">
                {label}
              </span>
            </div>
          </>
        ))}
      </div>
    )
  }
</div>

<script>
  import { splitRemainingMs } from "../data/countdown";

  let interval: ReturnType<typeof setInterval> | undefined;

  function initTimer() {
    if (interval) {
      clearInterval(interval);
      interval = undefined;
    }

    const timer = document.getElementById("event-timer");
    if (!timer) return;

    const target = Number(timer.dataset.timestamp) * 1000;
    const openMessage = timer.dataset.openMessage ?? "We're open!";
    const digits = timer.querySelectorAll("[data-digit]");

    function showOpen() {
      timer!.innerHTML = `<p class="font-averia text-[1.5em] font-bold text-timer-digit">${openMessage}</p>`;
    }

    function tick() {
      const remaining = target - Date.now();
      if (remaining <= 0) {
        showOpen();
        return false;
      }
      splitRemainingMs(remaining).forEach((digit, i) => {
        digits[i].textContent = digit;
      });
      return true;
    }

    if (!digits.length) return;

    tick();
    interval = setInterval(() => {
      if (!tick()) {
        clearInterval(interval);
        interval = undefined;
      }
    }, 1000);
  }

  initTimer();
  document.addEventListener("astro:page-load", initTimer);
</script>
