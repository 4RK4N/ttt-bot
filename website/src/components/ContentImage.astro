---
import type { ImageMetadata } from "astro";
import { getImage, Image } from "astro:assets";

interface Props {
  src: ImageMetadata;
  width: number;
  sizes: string;
  widths?: number[];
  class?: string;
  imageClass?: string;
  loading?: "lazy" | "eager";
  alt?: string;
  lightbox?: boolean;
}

const {
  src,
  width,
  sizes,
  widths,
  class: className,
  imageClass,
  loading = "lazy",
  alt = "",
  lightbox = false,
} = Astro.props;

const fullSrc =
  lightbox && alt
    ? (await getImage({ src, width: src.width, format: "webp" })).src
    : undefined;
---

{
  lightbox && alt ? (
    <button
      type="button"
      class:list={[
        "image-frame lightbox-trigger mx-auto max-w-full cursor-pointer p-0",
        className,
      ]}
      aria-label={alt}
      data-full-src={fullSrc}
    >
      <Image
        src={src}
        alt={alt}
        width={width}
        {...(widths ? { widths } : { densities: [1, 2] })}
        sizes={sizes}
        loading={loading}
        class:list={["block h-auto w-full", imageClass]}
      />
    </button>
  ) : (
    <div class:list={["image-frame mx-auto max-w-full", className]}>
      <Image
        src={src}
        alt={alt}
        width={width}
        {...(widths ? { widths } : { densities: [1, 2] })}
        sizes={sizes}
        loading={loading}
        class:list={["block h-auto w-full", imageClass]}
      />
    </div>
  )
}
