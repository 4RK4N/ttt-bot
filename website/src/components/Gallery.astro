---
import type { ImageMetadata } from 'astro';
import { Image } from 'astro:assets';

interface Props {
  images: ImageMetadata[];
  aspect?: 'portrait' | 'landscape' | 'square';
  cols?: 2 | 3;
  class?: string;
}

const { images, aspect = 'landscape', cols, class: className } = Astro.props;

const aspectClass = {
  portrait: 'aspect-[2/3]',
  landscape: 'aspect-[16/9]',
  square: 'aspect-square',
}[aspect];

const colsClass = cols
  ? { 2: 'grid-cols-2', 3: 'grid-cols-3' }[cols]
  : aspect === 'portrait'
    ? 'grid-cols-2 sm:grid-cols-3 lg:grid-cols-5'
    : 'grid-cols-1 sm:grid-cols-2';

const imageSizes =
  aspect === 'portrait'
    ? '(max-width: 640px) 45vw, (max-width: 1024px) 30vw, 180px'
    : '(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 360px';

const imageWidths = aspect === 'portrait' ? [120, 200, 360] : [360, 720];
---

<div class:list={['grid w-full gap-3', colsClass, className]}>
  {images.map((src) => (
    <Image
      src={src}
      alt=""
      widths={imageWidths}
      sizes={imageSizes}
      loading="lazy"
      class:list={['h-full w-full rounded-md object-cover', aspectClass]}
    />
  ))}
</div>
