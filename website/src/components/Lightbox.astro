<div
  id="lightbox"
  class="lightbox hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
  hidden
>
  <button
    type="button"
    id="lightbox-close"
    class="lightbox__close"
    aria-label="Close"
  >
    <svg
      viewBox="0 0 24 24"
      class="h-5 w-5 fill-none stroke-current stroke-2"
      aria-hidden="true"
    >
      <path d="M6 6l12 12M18 6L6 18"></path>
    </svg>
  </button>
  <button
    type="button"
    id="lightbox-prev"
    class="lightbox__btn lightbox__btn--prev"
    aria-label="Previous image"
  >
    <svg
      viewBox="0 0 24 24"
      class="h-6 w-6 fill-none stroke-current stroke-2"
      aria-hidden="true"
    >
      <path d="M15 6l-6 6 6 6"></path>
    </svg>
  </button>
  <img id="lightbox-image" class="lightbox__image" alt="" />
  <button
    type="button"
    id="lightbox-next"
    class="lightbox__btn lightbox__btn--next"
    aria-label="Next image"
  >
    <svg
      viewBox="0 0 24 24"
      class="h-6 w-6 fill-none stroke-current stroke-2"
      aria-hidden="true"
    >
      <path d="M9 6l6 6-6 6"></path>
    </svg>
  </button>
  <p id="lightbox-counter" class="lightbox__counter" aria-live="polite"></p>
</div>

<script>
  import { on, renewListenerScope } from "../lib/dom-listeners";

  let triggers: HTMLButtonElement[] = [];
  let current = 0;
  let lastFocus: HTMLButtonElement | null = null;
  let overlayAbort: AbortController | null = null;
  const documentScope = new AbortController();

  function getElements() {
    return {
      overlay: document.getElementById("lightbox") as HTMLDivElement | null,
      img: document.getElementById("lightbox-image") as HTMLImageElement | null,
      counter: document.getElementById(
        "lightbox-counter",
      ) as HTMLParagraphElement | null,
      closeBtn: document.getElementById(
        "lightbox-close",
      ) as HTMLButtonElement | null,
      prevBtn: document.getElementById(
        "lightbox-prev",
      ) as HTMLButtonElement | null,
      nextBtn: document.getElementById(
        "lightbox-next",
      ) as HTMLButtonElement | null,
    };
  }

  function imageSrc(source: HTMLImageElement): string {
    const src = source.currentSrc || source.src;
    if (src) return src;

    const srcset = source.getAttribute("srcset");
    if (!srcset) return "";

    const largest = srcset
      .split(",")
      .map((entry) => entry.trim().split(/\s+/))
      .sort((a, b) => {
        const wA = parseInt(a[1] || "0", 10);
        const wB = parseInt(b[1] || "0", 10);
        return wB - wA;
      })[0]?.[0];

    return largest || "";
  }

  function hide() {
    const { overlay, img } = getElements();
    if (!overlay || !img) return;

    overlay.classList.add("hidden");
    overlay.hidden = true;
    document.body.classList.remove("overflow-hidden");
    img.src = "";
    lastFocus?.focus();
  }

  function show(index: number) {
    if (!triggers.length) return;

    const { overlay, img, counter, closeBtn } = getElements();
    if (!overlay || !img || !counter || !closeBtn) return;

    current = (index + triggers.length) % triggers.length;
    const trigger = triggers[current];
    const source = trigger.querySelector<HTMLImageElement>("img");
    if (!source) return;

    const src = imageSrc(source);
    if (!src) return;

    img.src = src;
    img.alt = source.alt;
    counter.textContent = `${current + 1} / ${triggers.length}`;
    overlay.classList.remove("hidden");
    overlay.hidden = false;
    document.body.classList.add("overflow-hidden");
    closeBtn.focus();
  }

  function onTriggerClick(e: Event) {
    const trigger = e.currentTarget as HTMLButtonElement;
    lastFocus = trigger;
    const index = triggers.indexOf(trigger);
    if (index >= 0) show(index);
  }

  function resetLightboxOnNavigation() {
    document.body.classList.remove("overflow-hidden");
    const { overlay, img } = getElements();
    if (!overlay) return;

    overlay.classList.add("hidden");
    overlay.hidden = true;
    if (img) img.src = "";
  }

  function setupLightbox() {
    const els = getElements();
    if (
      !els.overlay ||
      !els.img ||
      !els.counter ||
      !els.closeBtn ||
      !els.prevBtn ||
      !els.nextBtn
    ) {
      return;
    }

    resetLightboxOnNavigation();

    overlayAbort = renewListenerScope(overlayAbort);
    const { signal } = overlayAbort;

    triggers = [
      ...document.querySelectorAll<HTMLButtonElement>(".lightbox-trigger"),
    ];
    triggers.forEach((trigger) => {
      on(trigger, "click", onTriggerClick, signal);
    });

    on(els.closeBtn, "click", hide, signal);
    on(els.prevBtn, "click", () => show(current - 1), signal);
    on(els.nextBtn, "click", () => show(current + 1), signal);

    on(
      els.overlay,
      "click",
      (e) => {
        if (e.target === els.overlay) hide();
      },
      signal,
    );
  }

  on(
    document,
    "keydown",
    (e) => {
      if (!(e instanceof KeyboardEvent)) return;
      const { overlay } = getElements();
      if (!overlay || overlay.hidden) return;

      if (e.key === "Escape") hide();
      else if (e.key === "ArrowLeft") show(current - 1);
      else if (e.key === "ArrowRight") show(current + 1);
    },
    documentScope.signal,
  );

  document.addEventListener("astro:before-swap", resetLightboxOnNavigation);
  document.addEventListener("astro:page-load", setupLightbox);
  setupLightbox();
</script>
