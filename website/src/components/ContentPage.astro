---
import Base from "../layouts/Base.astro";
import type { Lang } from "../data/nav";

interface Props {
  title: string;
  lang: Lang;
  path: string;
  heading: string;
  /** Rules pages use the wider column (760px); default is 680px text. */
  wide?: boolean;
  /** Gallery/guestbook pages use the widest column (900px). */
  gallery?: boolean;
  /** Long-form pages (about, rules) keep left-aligned body text. */
  centerBody?: boolean;
  /** Preload Pacifico (pages with h1 page-heading). Default true. */
  preloadPacifico?: boolean;
  /** Preload Patrick Hand (handwriting copy). Default true. */
  preloadPatrick?: boolean;
}

const {
  title,
  lang,
  path,
  heading,
  wide = false,
  gallery = false,
  centerBody = true,
  preloadPacifico = true,
  preloadPatrick = true,
} = Astro.props;
---

<Base
  title={title}
  lang={lang}
  path={path}
  preloadPacifico={preloadPacifico}
  preloadPatrick={preloadPatrick}
>
  <section
    class:list={[
      "content-section",
      wide && "content-section--wide",
      gallery && "content-section--gallery",
      centerBody && "content-section--center-body",
    ]}
  >
    <div class="section-head">
      <h1 class="page-heading">
        <span class="page-heading__text">{heading}</span>
      </h1>
      <div class="page-ornament" aria-hidden="true">
        <span class="page-ornament__diamond"></span>
      </div>
    </div>
    {
      Astro.slots.has("intro") && (
        <div class="page-intro">
          <slot name="intro" />
        </div>
      )
    }
    <slot />
  </section>
</Base>
