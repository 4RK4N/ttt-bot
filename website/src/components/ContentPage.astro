---
import Base from "../layouts/Base.astro";
import type { Lang } from "../data/nav";

interface Props {
  title: string;
  lang: Lang;
  path: string;
  heading: string;
  /** Rules pages use the wider column (45rem); default is 36rem. */
  wide?: boolean;
  /** Long-form pages (about, rules) keep left-aligned body text. */
  centerBody?: boolean;
}

const {
  title,
  lang,
  path,
  heading,
  wide = false,
  centerBody = true,
} = Astro.props;
---

<Base title={title} lang={lang} path={path}>
  <section
    class:list={[
      "content-section",
      wide && "content-section--wide",
      centerBody && "content-section--center-body",
    ]}
  >
    <h1 class="page-heading">
      <span class="page-heading__text" data-text={heading}>{heading}</span>
    </h1>
    <slot />
  </section>
</Base>
